{
  "name": "termpad",
  "version": "1.20.0",
  "description": "A desktop terminal profile launcher for predefined command sets.",
  "type": "module",
  "main": "desktop/main.js",
  "scripts": {
    "start": "node server.js",
    "desktop": "env -u ELECTRON_RUN_AS_NODE electron .",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir"
  },
  "build": {
    "appId": "com.termpad.app",
    "productName": "Termpad",
    "files": [
      "desktop/**/*",
      "public/**/*",
      "server.js"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "mac": {
      "target": "dmg"
    },
    "publish": {
      "provider": "github",
      "owner": "pkp2024",
      "repo": "termpad"
    }
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^24.13.3"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.3.9",
    "node-pty": "^1.1.0"
  }
}
